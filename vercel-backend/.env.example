# Copia este archivo como .env en la carpeta vercel-backend
# y añade estas variables también en el dashboard de Vercel

# ─── Discord App ──────────────────────────────────────────
# Desde https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ID de tu servidor Discord (clic derecho en el servidor → Copiar ID)
DISCORD_GUILD_ID=

# Opcional: ID del rol que debe tener el usuario para acceder
# (clic derecho en el rol → Copiar ID)
REQUIRED_ROLE_ID=
